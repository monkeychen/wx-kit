{
  "name": "wx-kit",
  "private": true,
  "version": "0.1.0",
  "description": "微信百宝箱 - 第一阶段：文章下载器",
  "main": "dist-electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "cli": "electron . "
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/turndown": "^5.0.5",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.0.0"
  },
  "build": {
    "appId": "com.wxkit.app",
    "productName": "wx-kit",
